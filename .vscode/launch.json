{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Story Pilot — Web",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "chrome",
      "toolArgs": [
        "--web-port=8473"
      ]
    },
    {
      "name": "Story Pilot — Web (emulator)",
      "request": "launch",
      "type": "dart",
